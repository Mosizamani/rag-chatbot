ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_API_KEY=
# Required in .pipe files (RocketRide substitute ${ROCKETRIDE_*} from .env)
ROCKETRIDE_GEMINI_API_KEY=
# MongoDB Atlas — host (e.g. cluster0.xxxxx.mongodb.net) and API key for the vector store in agents.pipe
ROCKETRIDE_MONGODB_HOST=
ROCKETRIDE_MONGODB_APIKEY=
ROCKETRIDE_MONGODB_DATABASE=weld_inspection
ROCKETRIDE_MONGODB_COLLECTION=documents
# Optional: same SRV as setup_mongo.py for get_rag_context() direct Mongo text snippets
MONGODB_ATLAS_SRV=
# If the DAP routes the question pipe by component type, set: RAG_PIPE_USE_CHAT=1
# RAG_PIPE_USE_CHAT=
# RAG_PIPE_PROVIDER=RAG_Node
# VISION_PIPE_PROVIDER=Vision_Node
GEMINI_API_KEY=
